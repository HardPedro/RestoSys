rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        hasRole('admin') || 
        (request.auth.token.email == "hardsoldisk001@gmail.com" && request.auth.token.email_verified == true)
      );
    }
    
    function isManager() {
      return hasRole('manager') || isAdmin();
    }
    
    function isWaiter() {
      return hasRole('waiter') || isManager();
    }
    
    function isKitchen() {
      return hasRole('kitchen') || isManager();
    }
    
    function isBar() {
      return hasRole('bar') || isManager();
    }
    
    function isCashier() {
      return hasRole('cashier') || isManager();
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() || resource.data.role == 'waiter';
      allow create: if isAdmin() || (request.auth.uid == userId && request.resource.data.role == 'waiter');
      allow update: if isAdmin() || (request.auth.uid == userId && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      // Anyone can read products (for the digital menu)
      allow read: if true;
      // Waiters need to update stock when placing orders
      allow write: if true;
    }

    match /recipes/{recipeId} {
      allow read: if true; // Waiters need to read recipes to deduct ingredients
      allow write: if isManager();
    }

    match /tables/{tableId} {
      allow read: if true;
      allow update: if 
        isAdmin() || isCashier() || (
          // Waiters can only change free -> occupied or occupied -> billing
          (resource.data.status == 'free' && request.resource.data.status == 'occupied') ||
          (resource.data.status == 'occupied' && request.resource.data.status == 'billing')
        );
      allow create, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if true;
      allow create: if true;
      allow update: if 
        isAdmin() || isCashier() || (
          // Waiters can only update open orders
          resource.data.status == 'open' && request.resource.data.status == 'open'
        );
      allow delete: if isAdmin();
    }

    match /orderItems/{itemId} {
      allow read: if true;
      allow create: if true;
      allow update: if 
        isAdmin() || isCashier() || isKitchen() || isBar() || (
          // Waiters can only update pending items
          resource.data.status == 'pending'
        );
      allow delete: if isAdmin() || isCashier();
    }

    match /transactions/{transactionId} {
      allow read: if isCashier() || isManager();
      allow write: if isCashier() || isManager();
    }

    match /stockMovements/{movementId} {
      allow read: if isManager();
      allow write: if true; // Waiters create stock movements when ordering
    }

    match /printJobs/{jobId} {
      allow read: if isCashier() || isManager();
      allow create: if true; // Waiters can create print jobs
      allow update: if isCashier() || isManager();
      allow delete: if isCashier() || isManager();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isManager();
    }
  }
}
